{
  "name": "automations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "libretto open --headed",
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "ABS_RUN_E2E=1 vitest run --config vitest.e2e.config.ts",
    "serve": "tsx src/server.ts",
    "serve:prod": "node dist/server.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "libretto": "^0.6.4"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "jsdom": "^29.1.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  }
}
